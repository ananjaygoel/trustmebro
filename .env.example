# TrustMeBro Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# NEWS API
# =============================================================================
NEWS_API_KEY=your_news_api_key_here

# =============================================================================
# AI/LLM APIs
# =============================================================================
# Google Gemini (primary AI for content rewriting)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_backup_gemini_api_key_here

# AIPipe keys (aipipe.org proxy - alternative AI provider)
AIPIPE_KEY_1=your_aipipe_key_1_here
AIPIPE_KEY_2=your_aipipe_key_2_here
AIPIPE_KEY_3=your_aipipe_key_3_here
AIPIPE_KEY_4=your_aipipe_key_4_here

# Groq API (for Q&A function)
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# CLOUDFLARE PAGES RUNTIME
# =============================================================================
PUBLIC_GA_ID=your_ga4_measurement_id_here
CONTACT_TO_EMAIL=hello@trustmebro.pro
NEWSLETTER_TO_EMAIL=hello@trustmebro.pro

# =============================================================================
# SOCIAL MEDIA - BLUESKY
# =============================================================================
BLUESKY_HANDLE=your_bluesky_handle_here
BLUESKY_APP_PASSWORD=your_bluesky_app_password_here

# =============================================================================
# SOCIAL MEDIA - TWITTER/X
# =============================================================================
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# =============================================================================
# SOCIAL MEDIA - REDDIT
# =============================================================================
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here
