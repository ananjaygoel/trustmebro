---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  categoryEmoji?: string;
  date: Date;
  image?: string;
  source?: string;
  featured?: boolean;
}

const {
  title,
  slug,
  excerpt,
  category,
  categoryEmoji = '📰',
  date,
  image,
  source,
  featured = false
} = Astro.props;

const displayDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const timeAgo = (value: Date) => {
  const seconds = Math.floor((Date.now() - value.getTime()) / 1000);
  if (seconds < 3600) return `${Math.max(1, Math.floor(seconds / 60))}m ago`;
  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;
  return `${Math.floor(seconds / 86400)}d ago`;
};
---

<article class:list={['card group h-full', featured && 'md:col-span-2']}>
  <a href={`/posts/${slug}`} class="flex h-full flex-col">
    <div class:list={['overflow-hidden border-b border-[var(--color-border)]', featured ? 'aspect-[16/10]' : 'aspect-[4/3]']}>
      {image ? (
        <img
          src={image}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center gradient-bg text-4xl text-white">
          {categoryEmoji}
        </div>
      )}
    </div>

    <div class="flex flex-1 flex-col gap-4 p-5 md:p-6">
      <div class="flex flex-wrap items-center gap-2 text-[0.72rem] uppercase tracking-[0.16em] text-[var(--color-text-muted)]">
        <span class="inline-flex items-center gap-1 text-[var(--color-accent-cool)]">
          <span>{categoryEmoji}</span>
          <span>{category}</span>
        </span>
        {source && (
          <>
            <span class="opacity-40">•</span>
            <span>{source}</span>
          </>
        )}
      </div>

      <div class="space-y-3">
        <h3 class:list={[
          'font-heading leading-tight text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent-cool)]',
          featured ? 'text-3xl md:text-4xl' : 'text-2xl'
        ]}>
          {title}
        </h3>
        <p class="muted-copy text-[0.96rem] line-clamp-3">{excerpt}</p>
      </div>

      <div class="mt-auto flex items-center justify-between gap-3 border-t border-[var(--color-border)] pt-4 text-sm text-[var(--color-text-muted)]">
        <time datetime={date.toISOString()}>{displayDate}</time>
        <span>{timeAgo(date)}</span>
      </div>
    </div>
  </a>
</article>
