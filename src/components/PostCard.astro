---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  categoryEmoji?: string;
  date: Date;
  image?: string;
  featured?: boolean;
}

const { title, slug, excerpt, category, categoryEmoji = '📰', date, image, featured = false } = Astro.props;

const timeAgo = (date: Date) => {
  const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
  if (seconds < 60) return 'just now';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
};
---

<article class={`card group ${featured ? 'md:col-span-2 md:row-span-2' : ''}`}>
  <a href={`/posts/${slug}`} class="block">
    <!-- Image -->
    <div class={`relative overflow-hidden ${featured ? 'h-64 md:h-80' : 'h-44'}`}>
      {image ? (
        <img 
          src={image} 
          alt={title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full gradient-bg flex items-center justify-center text-4xl">
          {categoryEmoji}
        </div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      
      {featured && (
        <span class="absolute top-4 left-4 px-3 py-1 rounded-full bg-black/70 backdrop-blur-sm text-xs font-bold animate-pulse">
          🔴 FEATURED
        </span>
      )}
    </div>
    
    <!-- Content -->
    <div class="p-4">
      <span class="text-xs font-semibold text-cyan-400 uppercase tracking-wide">
        {categoryEmoji} {category}
      </span>
      <h3 class={`font-bold mt-2 mb-2 line-clamp-2 group-hover:text-cyan-400 transition-colors ${featured ? 'text-xl md:text-2xl' : 'text-base'}`}>
        {title}
      </h3>
      <p class="text-gray-400 text-sm line-clamp-2 mb-3">{excerpt}</p>
      <div class="flex justify-between items-center text-xs text-gray-500">
        <span>{timeAgo(date)}</span>
      </div>
    </div>
  </a>
  
  <!-- Action Buttons -->
  <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
    <button class="w-9 h-9 rounded-full bg-black/70 backdrop-blur-sm flex items-center justify-center hover:bg-purple-500 transition-all" title="Bookmark">
      🔖
    </button>
    <button class="share-btn w-9 h-9 rounded-full bg-black/70 backdrop-blur-sm flex items-center justify-center hover:bg-purple-500 transition-all" data-url={`/posts/${slug}`} data-title={title} title="Share">
      📤
    </button>
  </div>
</article>

<script>
  document.querySelectorAll('.share-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const url = window.location.origin + (btn as HTMLElement).dataset.url;
      const title = (btn as HTMLElement).dataset.title;
      
      if (navigator.share) {
        await navigator.share({ title, url });
      } else {
        await navigator.clipboard.writeText(url);
        (btn as HTMLElement).textContent = '✅';
        setTimeout(() => (btn as HTMLElement).textContent = '📤', 2000);
      }
    });
  });
</script>
