---
import { categories as allCategories } from '../lib/constants';

const categories = allCategories.filter((cat) =>
  ['tech', 'ai', 'gaming', 'entertainment', 'business', 'world'].includes(cat.slug)
);

const todayLabel = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<div class="border-b border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
  <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-2 text-xs md:flex-row md:items-center md:justify-between">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[var(--color-text-muted)]">
      <span class="eyebrow" style="margin-bottom: 0; font-size: 11px;">TrustMeBro desk</span>
      <span>Source-first summaries</span>
      <span>Searchable archive</span>
    </div>
    <span class="text-[var(--color-text-muted)]">{todayLabel}</span>
  </div>
</div>

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[color:var(--color-bg-secondary)]/95 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="min-w-0">
        <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-text-muted)]">Daily briefing</p>
        <div class="font-heading text-3xl leading-none tracking-[-0.04em] text-[var(--color-text)]">TrustMeBro</div>
      </a>

      <nav class="hidden lg:flex items-center gap-2">
        <a href="/" class="header-link">Home</a>
        {categories.map((cat) => (
          <a href={`/category/${cat.slug}`} class="header-link">{cat.name}</a>
        ))}
      </nav>

      <div class="hidden md:flex items-center gap-2">
        <a href="/search" class="header-link">Search</a>
        <a href="/saved" class="header-link">Saved</a>
        <a href="/#briefing" class="button-primary rounded-full px-4 py-2 text-sm">Get the briefing</a>
        <button id="theme-toggle" class="header-icon" aria-label="Toggle theme">☾</button>
      </div>

      <button id="mobile-menu-btn" class="header-icon md:hidden" aria-label="Open menu">☰</button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="mobile-panel hidden">
  <div class="max-w-sm ml-auto min-h-screen bg-[var(--color-bg-secondary)] px-6 py-6 shadow-2xl">
    <div class="flex items-center justify-between border-b border-[var(--color-border)] pb-4">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-text-muted)]">TrustMeBro</p>
        <p class="font-heading text-2xl text-[var(--color-text)]">Navigation</p>
      </div>
      <button id="mobile-close" class="header-icon" aria-label="Close menu">✕</button>
    </div>

    <nav class="mt-6 flex flex-col gap-2">
      <a href="/" class="mobile-link">Home</a>
      <a href="/search" class="mobile-link">Search</a>
      <a href="/saved" class="mobile-link">Saved</a>
      <a href="/archive" class="mobile-link">Archive</a>
      <a href="/#briefing" class="mobile-link">Get the briefing</a>
      {categories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="mobile-link">{cat.name}</a>
      ))}
      <button id="mobile-theme-toggle" class="mobile-link text-left" type="button">Toggle theme</button>
    </nav>
  </div>
</div>

<style>
  .header-link {
    border-radius: 999px;
    padding: 0.55rem 0.95rem;
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .header-link:hover {
    background: var(--color-glass);
    color: var(--color-text);
  }

  .header-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-glass);
    color: var(--color-text);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .header-icon:hover {
    background: var(--color-bg-tertiary);
    border-color: var(--color-border-strong);
  }

  .mobile-panel {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgba(24, 34, 45, 0.2);
    backdrop-filter: blur(6px);
  }

  .mobile-link {
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    padding: 0.95rem 1rem;
    color: var(--color-text);
    background: var(--color-glass);
  }
</style>

<script>
  const mobileMenu = document.getElementById('mobile-menu');
  const openMenu = document.getElementById('mobile-menu-btn');
  const closeMenu = document.getElementById('mobile-close');
  const mobileThemeToggle = document.getElementById('mobile-theme-toggle');

  function toggleTheme() {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncThemeToggle();
  }

  function syncThemeToggle() {
    const isDark = document.documentElement.classList.contains('dark');
    const desktop = document.getElementById('theme-toggle');
    const mobile = document.getElementById('mobile-theme-toggle');
    if (desktop) desktop.textContent = isDark ? '☀︎' : '☾';
    if (mobile) mobile.textContent = isDark ? 'Switch to light mode' : 'Switch to dark mode';
  }

  openMenu?.addEventListener('click', () => {
    mobileMenu?.classList.remove('hidden');
  });

  closeMenu?.addEventListener('click', () => {
    mobileMenu?.classList.add('hidden');
  });

  mobileMenu?.addEventListener('click', (event) => {
    if (event.target === mobileMenu) {
      mobileMenu.classList.add('hidden');
    }
  });

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  mobileThemeToggle?.addEventListener('click', toggleTheme);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      mobileMenu?.classList.add('hidden');
    }
  });

  syncThemeToggle();
</script>
