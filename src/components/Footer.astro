---
const year = new Date().getFullYear();
---

<footer class="bg-[#0a0d15] border-t border-white/5 mt-20">
  <!-- Newsletter Section -->
  <div class="border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold gradient-text mb-4">stay in the loop 📬</h2>
        <p class="text-gray-400 mb-8">get the freshest news drops straight to your inbox. no spam, just vibes.</p>
        <form id="newsletter-form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="flex gap-3 max-w-md mx-auto">
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
          <input 
            type="email" 
            name="email"
            placeholder="your@email.com" 
            required
            class="flex-1 px-6 py-4 rounded-xl bg-[#0f1724] border border-white/10 focus:outline-none focus:border-purple-500 transition-all"
          />
          <button type="submit" class="px-8 py-4 rounded-xl gradient-bg font-bold text-black hover:scale-105 transition-all whitespace-nowrap">
            subscribe 🚀
          </button>
        </form>
        <div id="newsletter-message" class="mt-4 hidden"></div>
      </div>
    </div>
  </div>
  
  <!-- Footer Links -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <h3 class="font-bold text-purple-400 mb-4">Categories</h3>
        <ul class="space-y-2 text-gray-400">
          <li><a href="/category/tech" class="hover:text-cyan-400 transition-colors">💻 Tech</a></li>
          <li><a href="/category/business" class="hover:text-cyan-400 transition-colors">💰 Business</a></li>
          <li><a href="/category/science" class="hover:text-cyan-400 transition-colors">🔬 Science</a></li>
          <li><a href="/category/world" class="hover:text-cyan-400 transition-colors">🌍 World</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-purple-400 mb-4">More</h3>
        <ul class="space-y-2 text-gray-400">
          <li><a href="/category/sports" class="hover:text-cyan-400 transition-colors">⚽ Sports</a></li>
          <li><a href="/category/entertainment" class="hover:text-cyan-400 transition-colors">🎬 Entertainment</a></li>
          <li><a href="/category/health" class="hover:text-cyan-400 transition-colors">🏥 Health</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-purple-400 mb-4">About</h3>
        <ul class="space-y-2 text-gray-400">
          <li><a href="/about" class="hover:text-cyan-400 transition-colors">About Us</a></li>
          <li><a href="/privacy" class="hover:text-cyan-400 transition-colors">Privacy</a></li>
          <li><a href="/contact" class="hover:text-cyan-400 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-purple-400 mb-4">Follow</h3>
        <div class="flex gap-3">
          <a href="https://twitter.com/trustmebro" target="_blank" class="w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-[#1da1f2] transition-all">𝕏</a>
          <a href="https://instagram.com/trustmebro" target="_blank" class="w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-pink-500 transition-all">📸</a>
          <a href="https://discord.gg/trustmebro" target="_blank" class="w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-[#5865F2] transition-all">💬</a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Bottom Bar -->
  <div class="border-t border-white/5 py-6">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center text-sm">🔥</div>
        <span>TrustMeBro © {year}</span>
      </div>
      <div>made with 💜 for the chronically online</div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const msg = document.getElementById('newsletter-message');
    const btn = form.querySelector('button');
    
    if (btn) btn.textContent = 'subscribing...';
    
    try {
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as any).toString()
      });
      
      if (response.ok) {
        if (msg) {
          msg.classList.remove('hidden');
          msg.className = 'mt-4 text-green-400';
          msg.textContent = '✅ you\'re in! welcome to the squad';
        }
        form.reset();
      } else {
        throw new Error('Failed');
      }
    } catch (err) {
      if (msg) {
        msg.classList.remove('hidden');
        msg.className = 'mt-4 text-red-400';
        msg.textContent = '❌ something went wrong, try again?';
      }
    }
    if (btn) btn.textContent = 'subscribe 🚀';
  });
</script>
