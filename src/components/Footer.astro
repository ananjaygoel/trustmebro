---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
  <div class="max-w-7xl mx-auto px-4 py-14">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_repeat(3,minmax(0,1fr))]">
      <div class="space-y-4">
        <p class="eyebrow">TrustMeBro</p>
        <h2 class="section-title text-3xl">A calmer read on the internet's noisiest news cycle.</h2>
        <p class="muted-copy max-w-xl">
          We keep the product simple: clear story pages, visible source labels when available,
          a searchable archive, and a briefing signup that actually works.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href="/archive" class="button-secondary">Open archive</a>
          <a href="/#briefing" class="button-secondary">Get the briefing</a>
        </div>
      </div>

      <div>
        <h3 class="footer-heading">Sections</h3>
        <ul class="footer-list">
          <li><a href="/category/tech">Tech</a></li>
          <li><a href="/category/ai">AI</a></li>
          <li><a href="/category/gaming">Gaming</a></li>
          <li><a href="/category/entertainment">Entertainment</a></li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">Explore</h3>
        <ul class="footer-list">
          <li><a href="/search">Search</a></li>
          <li><a href="/saved">Saved articles</a></li>
          <li><a href="/categories">All categories</a></li>
          <li><a href="/rss.xml">RSS feed</a></li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">About</h3>
        <ul class="footer-list">
          <li><a href="/about">About</a></li>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-[var(--color-border)] pt-6 text-sm text-[var(--color-text-muted)] md:flex-row md:items-center md:justify-between">
      <p>TrustMeBro © {year}. Built for fast reading, not endless clicking.</p>
      <div class="flex items-center gap-4">
        <a href="https://twitter.com/trustmebro111" target="_blank" rel="noreferrer" class="footer-social">X</a>
        <a href="https://bsky.app/profile/trustmebro.bsky.social" target="_blank" rel="noreferrer" class="footer-social">Bluesky</a>
        <a href="/rss.xml" class="footer-social">RSS</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-heading {
    margin-bottom: 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .footer-list {
    display: grid;
    gap: 0.75rem;
    color: var(--color-text-secondary);
  }

  .footer-list a,
  .footer-social {
    transition: color 0.2s ease;
  }

  .footer-list a:hover,
  .footer-social:hover {
    color: var(--color-accent-cool);
  }
</style>
