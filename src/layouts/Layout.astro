---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string[];
}

const { 
  title, 
  description = "GenZ news that hits different. No cap.", 
  image = "/og-image.png",
  article = false,
  publishedTime,
  modifiedTime,
  author = "TrustMeBro",
  keywords = ["news", "genz", "trending", "viral"]
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://trustmebro.pro");
const fullImageURL = image.startsWith('http') ? image : new URL(image, Astro.site || "https://trustmebro.pro").toString();

// Analytics & Ads IDs
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_ID || "";
const ADSENSE_CLIENT_ID = "ca-pub-7689171652945488";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f3ede2" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Primary Meta Tags -->
    <title>{title} | TrustMeBro</title>
    <meta name="title" content={`${title} | TrustMeBro`} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageURL} />
    <meta property="og:site_name" content="TrustMeBro" />
    <meta property="og:locale" content="en_US" />
    
    {article && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {article && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {article && (
      <meta property="article:author" content={author} />
    )}
    
    <!-- Google News specific tags -->
    {article && (
      <>
        <meta name="news_keywords" content={keywords.join(", ")} />
        <meta name="original-source" content={canonicalURL} />
      </>
    )}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageURL} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700;6..72,800&display=swap" rel="stylesheet" />
    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="TrustMeBro RSS" href="/rss.xml" />

    <!-- Google AdSense -->
    {ADSENSE_CLIENT_ID && (
      <script 
        async 
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT_ID}`}
        crossorigin="anonymous"
      ></script>
    )}

    <!-- Google News Reader Revenue Manager -->
    <script async type="application/javascript" src="https://news.google.com/swg/js/v1/swg-basic.js"></script>
    <script is:inline>
      (self.SWG_BASIC = self.SWG_BASIC || []).push(function(basicSubscriptions) {
        basicSubscriptions.init({
          type: "NewsArticle",
          isPartOfType: ["Product"],
          isPartOfProductId: "CAowucjDDA:openaccess",
          clientOptions: { theme: "light", lang: "en" },
        });
      });
    </script>
    
    <!-- JSON-LD Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": article ? "NewsArticle" : "WebSite",
      "name": "TrustMeBro",
      "url": canonicalURL,
      "description": description,
      "publisher": {
        "@type": "Organization",
        "name": "TrustMeBro",
        "logo": {
          "@type": "ImageObject",
          "url": "https://trustmebro.pro/apple-touch-icon.png"
        }
      },
      ...(article && {
        "headline": title,
        "image": fullImageURL,
        "datePublished": publishedTime,
        "dateModified": modifiedTime || publishedTime,
        "author": {
          "@type": "Person",
          "name": author
        }
      })
    })} />

    <script is:inline>
      (() => {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="antialiased">
    <slot />

    <!-- Cookie Consent Banner -->
    <div id="cookie-banner" style="display: none; position: fixed; bottom: 1rem; left: 1rem; right: 1rem; background: rgba(253, 250, 244, 0.95); padding: 1rem 1.25rem; z-index: 9999; border: 1px solid rgba(24, 34, 45, 0.12); border-radius: 1.25rem; box-shadow: 0 20px 50px rgba(24, 34, 45, 0.12); backdrop-filter: blur(14px);">
      <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
        <p style="margin: 0; color: #41505d; font-size: 0.9rem; flex: 1;">
          We use cookies for analytics and a few quality-of-life features. Read the full
          <a href="/privacy" style="color: #1f5368; text-decoration: underline;">privacy policy</a>.
        </p>
        <div style="display: flex; gap: 0.5rem;">
          <button id="reject-cookies" style="padding: 0.6rem 1rem; background: transparent; border: 1px solid rgba(24, 34, 45, 0.12); color: #41505d; border-radius: 999px; cursor: pointer; font-size: 0.85rem;">Reject</button>
          <button id="accept-cookies" style="padding: 0.6rem 1.2rem; background: #1f5368; border: none; color: #fffdf8; border-radius: 999px; cursor: pointer; font-weight: 600; font-size: 0.85rem;">Accept</button>
        </div>
      </div>
    </div>
    
    <!-- Google Analytics (loads only after consent) -->
    {GA_MEASUREMENT_ID && (
      <script is:inline define:vars={{ gaId: GA_MEASUREMENT_ID }}>
        // Check if user already consented
        (function() {
          var consent = localStorage.getItem('cookie-consent');
          var banner = document.getElementById('cookie-banner');
          
          function loadGoogleAnalytics() {
            // Load GA script
            var script = document.createElement('script');
            script.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
            script.async = true;
            document.head.appendChild(script);
            
            window.dataLayer = window.dataLayer || [];
            function gtag(){window.dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', gaId);
          }
          
          if (consent === 'accepted') {
            loadGoogleAnalytics();
          } else if (consent !== 'rejected' && banner) {
            // Show banner if no choice made yet
            banner.style.display = 'block';
          }
          
          document.getElementById('accept-cookies')?.addEventListener('click', function() {
            localStorage.setItem('cookie-consent', 'accepted');
            if (banner) banner.style.display = 'none';
            loadGoogleAnalytics();
          });
          
          document.getElementById('reject-cookies')?.addEventListener('click', function() {
            localStorage.setItem('cookie-consent', 'rejected');
            if (banner) banner.style.display = 'none';
          });
        })();
      </script>
    )}
    
    <!-- Cloudflare Web Analytics (privacy-friendly, no consent needed) -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "784aa4d8313849a9b16d504b4beb9613"}'></script>
  </body>
</html>
