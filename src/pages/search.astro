---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Prepare posts data for client-side search
const searchData = posts.map(post => ({
  slug: post.slug,
  title: post.data.title,
  excerpt: post.data.excerpt,
  category: post.data.category,
  date: post.data.date.toISOString(),
  image: post.data.image,
  author: post.data.author,
}));
---

<Layout title="Search - trust me bro" description="Search all stories on trust me bro">
  <Header />
  
  <main class="min-h-screen bg-[--color-bg-primary] pt-8 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Search Header -->
      <div class="mb-8 text-center">
        <h1 class="text-4xl md:text-5xl font-black mb-4">
          <span class="gradient-text">Search</span> Stories
        </h1>
        <p class="text-[--color-text-secondary] text-lg">
          Find the tea you're looking for ☕
        </p>
      </div>

      <!-- Search Input -->
      <div class="relative mb-8">
        <input
          type="text"
          id="search-input"
          placeholder="Type to search..."
          class="w-full px-6 py-4 pl-14 text-lg rounded-2xl bg-[--color-bg-secondary] border-2 border-transparent focus:border-[--color-neon-purple] text-[--color-text-primary] placeholder:text-[--color-text-muted] outline-none transition-all"
          autofocus
        />
        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-6 h-6 text-[--color-text-muted]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <button 
          id="clear-search"
          class="absolute right-4 top-1/2 -translate-y-1/2 p-2 rounded-full hover:bg-[--color-bg-tertiary] text-[--color-text-muted] hidden"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Search Stats -->
      <div id="search-stats" class="mb-6 text-[--color-text-secondary] text-sm hidden">
        <span id="result-count">0</span> results for "<span id="search-term" class="font-semibold text-[--color-neon-purple]"></span>"
      </div>

      <!-- Results Container -->
      <div id="search-results" class="space-y-4">
        <!-- Initial state: show all posts -->
      </div>

      <!-- No Results -->
      <div id="no-results" class="text-center py-16 hidden">
        <div class="text-6xl mb-4">🤷</div>
        <h2 class="text-2xl font-bold text-[--color-text-primary] mb-2">No results found</h2>
        <p class="text-[--color-text-secondary]">Try searching for something else!</p>
      </div>

      <!-- Initial Posts (shown before search) -->
      <div id="initial-posts">
        <h2 class="text-xl font-bold text-[--color-text-primary] mb-4">Recent Stories</h2>
        <div class="space-y-4">
          {posts.slice(0, 10).map(post => (
            <a 
              href={`/posts/${post.slug}`}
              class="block p-4 rounded-xl bg-[--color-bg-secondary] hover:bg-[--color-bg-tertiary] transition-all group"
            >
              <div class="flex gap-4">
                {post.data.image && (
                  <img 
                    src={post.data.image} 
                    alt="" 
                    class="w-20 h-20 object-cover rounded-lg flex-shrink-0"
                  />
                )}
                <div class="flex-1 min-w-0">
                  <span class="text-xs font-semibold text-[--color-neon-purple] uppercase tracking-wide">
                    {post.data.category}
                  </span>
                  <h3 class="font-bold text-[--color-text-primary] group-hover:text-[--color-neon-pink] transition-colors line-clamp-2 mt-1">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-[--color-text-secondary] line-clamp-1 mt-1">
                    {post.data.excerpt}
                  </p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ searchData }}>
    const input = document.getElementById('search-input');
    const clearBtn = document.getElementById('clear-search');
    const resultsContainer = document.getElementById('search-results');
    const noResults = document.getElementById('no-results');
    const initialPosts = document.getElementById('initial-posts');
    const searchStats = document.getElementById('search-stats');
    const resultCount = document.getElementById('result-count');
    const searchTermDisplay = document.getElementById('search-term');

    // HTML escape function to prevent XSS
    function escapeHtml(str) {
      if (typeof str !== 'string') {
        return '';
      }
      const htmlEscapes = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      };
      return str.replace(/[&<>"']/g, function(char) {
        return htmlEscapes[char] || char;
      });
    }

    function formatDate(dateStr) {
      const date = new Date(dateStr);
      const now = new Date();
      const diff = now - date;
      const hours = Math.floor(diff / (1000 * 60 * 60));
      const days = Math.floor(hours / 24);
      
      if (hours < 1) return 'Just now';
      if (hours < 24) return `${hours}h ago`;
      if (days < 7) return `${days}d ago`;
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function search(query) {
      if (!query.trim()) {
        resultsContainer.innerHTML = '';
        noResults.classList.add('hidden');
        initialPosts.classList.remove('hidden');
        searchStats.classList.add('hidden');
        clearBtn.classList.add('hidden');
        return;
      }

      clearBtn.classList.remove('hidden');
      initialPosts.classList.add('hidden');

      const q = query.toLowerCase();
      const results = searchData.filter(post => 
        post.title.toLowerCase().includes(q) ||
        post.excerpt.toLowerCase().includes(q) ||
        post.category.toLowerCase().includes(q) ||
        post.author.toLowerCase().includes(q)
      );

      searchTermDisplay.textContent = query;
      resultCount.textContent = results.length;
      searchStats.classList.remove('hidden');

      if (results.length === 0) {
        resultsContainer.innerHTML = '';
        noResults.classList.remove('hidden');
        return;
      }

      noResults.classList.add('hidden');
      resultsContainer.innerHTML = results.map(post => {
        // Sanitize all user-controlled data before rendering
        const safeSlug = encodeURIComponent(post.slug || '');
        const safeImage = escapeHtml(post.image || '');
        const safeCategory = escapeHtml(post.category || '');
        const safeTitle = escapeHtml(post.title || '');
        const safeExcerpt = escapeHtml(post.excerpt || '');

        return `
          <a
            href="/posts/${safeSlug}"
            class="block p-4 rounded-xl bg-[--color-bg-secondary] hover:bg-[--color-bg-tertiary] transition-all group"
          >
            <div class="flex gap-4">
              ${safeImage ? `
                <img
                  src="${safeImage}"
                  alt=""
                  class="w-20 h-20 object-cover rounded-lg flex-shrink-0"
                />
              ` : ''}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-semibold text-[--color-neon-purple] uppercase tracking-wide">
                    ${safeCategory}
                  </span>
                  <span class="text-xs text-[--color-text-muted]">•</span>
                  <span class="text-xs text-[--color-text-muted]">${formatDate(post.date)}</span>
                </div>
                <h3 class="font-bold text-[--color-text-primary] group-hover:text-[--color-neon-pink] transition-colors line-clamp-2">
                  ${highlightMatch(safeTitle, query)}
                </h3>
                <p class="text-sm text-[--color-text-secondary] line-clamp-1 mt-1">
                  ${highlightMatch(safeExcerpt, query)}
                </p>
              </div>
            </div>
          </a>
        `;
      }).join('');
    }

    function highlightMatch(text, query) {
      if (!query.trim()) return text;
      const regex = new RegExp(`(${escapeRegex(query)})`, 'gi');
      return text.replace(regex, '<mark class="bg-[--color-neon-purple]/30 text-[--color-text-primary] px-0.5 rounded">$1</mark>');
    }

    function escapeRegex(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    // Debounce search
    let timeout;
    input.addEventListener('input', (e) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => search(e.target.value), 150);
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      search('');
      input.focus();
    });

    // Handle URL query param
    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get('q');
    if (q) {
      input.value = q;
      search(q);
    }
  </script>
</Layout>
