---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { categoryEmojis } from '../../lib/constants';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const getPostDate = () => (post.data.publishedAt ? new Date(post.data.publishedAt) : post.data.date);
const publishedDate = getPostDate();

const formatExactTimestamp = (date: Date) =>
  date.toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });

const content = post.body || '';
const wordCount = content.split(/\s+/).filter((word) => word.length > 0).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter((entry) => entry.slug !== post.slug && entry.data.category === post.data.category)
  .slice(0, 3);

const askEnabled = import.meta.env.PUBLIC_ENABLE_ASK === 'true';
const publishedTime = post.data.publishedAt || post.data.date.toISOString();
const modifiedTime = post.data.publishedAt || post.data.date.toISOString();
const sourceLabel = post.data.source || 'TrustMeBro desk';
---

<Layout
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.image}
  article={true}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  author={post.data.author}
  keywords={[post.data.category, 'news', 'trending']}
>
  <Header />

  <main class="px-4 py-10 md:py-14">
    <article class="max-w-6xl mx-auto">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
        <div class="space-y-5">
          <a href={`/category/${post.data.category}`} class="eyebrow inline-flex items-center gap-2" style="margin-bottom: 0;">
            <span>{categoryEmojis[post.data.category] || '📰'}</span>
            <span>{post.data.category}</span>
          </a>

          <h1 class="section-title text-4xl md:text-6xl">
            {post.data.title}
          </h1>

          <p class="muted-copy max-w-3xl text-lg md:text-xl">
            {post.data.excerpt}
          </p>

          <div class="flex flex-wrap gap-3 pt-2">
            <button id="share-story" class="button-primary">Share story</button>
            <button
              id="bookmark-btn"
              class="button-secondary"
              data-slug={post.slug}
              data-title={post.data.title}
              data-image={post.data.image}
              data-category={post.data.category}
              title="Save article"
            >
              Save article
            </button>
            <a href={`/category/${post.data.category}`} class="button-secondary">
              More from {post.data.category}
            </a>
          </div>
        </div>

        <aside class="surface self-start rounded-[1.75rem] p-6 lg:sticky lg:top-24">
          <p class="eyebrow">Story details</p>
          <dl class="space-y-5">
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Published</dt>
              <dd class="mt-1 font-medium text-[var(--color-text)]">{formatExactTimestamp(publishedDate)}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Byline</dt>
              <dd class="mt-1 font-medium text-[var(--color-text)]">{post.data.author}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Reading time</dt>
              <dd class="mt-1 font-medium text-[var(--color-text)]">{readingTime} min read</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Source label</dt>
              <dd class="mt-1 font-medium text-[var(--color-text)]">{sourceLabel}</dd>
            </div>
          </dl>
          <p class="mt-6 text-sm text-[var(--color-text-secondary)]">
            We show the original source label whenever it is available in the post metadata.
          </p>
        </aside>
      </div>

      {post.data.image && (
        <figure class="mt-10 overflow-hidden rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="max-h-[520px] w-full object-cover"
          />
          <figcaption class="border-t border-[var(--color-border)] px-5 py-4 text-sm text-[var(--color-text-muted)]">
            {post.data.source ? `Source: ${post.data.source}` : 'Image supplied with the story metadata.'}
          </figcaption>
        </figure>
      )}

      <div class="mt-12 grid gap-10 lg:grid-cols-[minmax(0,1fr)_280px]">
        <div class="prose max-w-none">
          <Content />
        </div>

        <aside class="space-y-5 lg:sticky lg:top-24 self-start">
          <div class="surface rounded-[1.5rem] p-5">
            <p class="eyebrow">Source note</p>
            <p class="muted-copy text-sm">
              This page keeps the byline, section, publish time, and source label together so the story is easier to scan and verify quickly.
            </p>
          </div>

          <div class="surface rounded-[1.5rem] p-5">
            <p class="eyebrow">Useful next step</p>
            <a href={`/category/${post.data.category}`} class="button-secondary w-full justify-between">
              Browse more {post.data.category}
              <span>→</span>
            </a>
          </div>
        </aside>
      </div>

      <div class="mt-12 space-y-6">
        {askEnabled && (
          <div class="surface rounded-[1.75rem] p-6" id="ask-widget">
            <h3 class="font-heading text-3xl">Ask a follow-up about this story</h3>
            <p class="muted-copy mt-2 text-sm">
              Ask a question tied to the article content. Responses are AI-generated from the text on this page.
            </p>

            <div class="mt-5 flex flex-col gap-3 md:flex-row">
              <input
                type="text"
                id="ask-input"
                placeholder="What changed, and why does it matter?"
                class="min-h-[3.25rem] flex-1 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-5 text-sm text-[var(--color-text)] outline-none transition-all placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-accent-cool)]"
                maxlength="500"
              />
              <button
                id="ask-btn"
                class="button-primary min-h-[3.25rem] justify-center rounded-full px-6"
              >
                Ask
              </button>
            </div>

            <div id="ask-response" class="mt-4 hidden">
              <div id="ask-loading" class="text-sm text-[var(--color-text-muted)] hidden">Thinking…</div>
              <div id="ask-answer" class="surface mt-3 hidden rounded-[1.25rem] p-4 text-sm">
                <p id="ask-answer-text" class="muted-copy"></p>
              </div>
              <div id="ask-error" class="mt-3 text-sm text-[var(--color-accent-strong)] hidden"></div>
            </div>
          </div>
        )}

        <NewsletterSignup
          id="article-briefing"
          title="Get the next useful briefing"
          description="If this story was worth your time, the next one should be too. Get the daily briefing in one clean email."
          buttonLabel="Join the briefing"
        />

        <div class="surface rounded-[1.75rem] p-6">
          <p class="eyebrow">Reader reaction</p>
          <div class="flex flex-wrap gap-3" id="reactions-container" data-slug={post.slug}>
            <button class="reaction-btn pill px-4 py-3" data-reaction="fire">
              🔥 <span class="count font-semibold">0</span>
            </button>
            <button class="reaction-btn pill px-4 py-3" data-reaction="cap">
              🧢 <span class="count font-semibold">0</span>
            </button>
            <button class="reaction-btn pill px-4 py-3" data-reaction="skull">
              💀 <span class="count font-semibold">0</span>
            </button>
            <button class="reaction-btn pill px-4 py-3" data-reaction="goat">
              🐐 <span class="count font-semibold">0</span>
            </button>
          </div>
          <p class="mt-3 text-sm text-[var(--color-text-muted)]" id="vote-status"></p>
        </div>
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="max-w-7xl mx-auto mt-16">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="eyebrow">Continue reading</p>
            <h2 class="font-heading text-4xl">More from this section</h2>
          </div>
          <a href={`/category/${post.data.category}`} class="button-secondary">More {post.data.category}</a>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {relatedPosts.map((related) => (
            <PostCard
              title={related.data.title}
              slug={related.slug}
              excerpt={related.data.excerpt}
              category={related.data.category}
              categoryEmoji={categoryEmojis[related.data.category] || '📰'}
              date={related.data.publishedAt ? new Date(related.data.publishedAt) : related.data.date}
              image={related.data.image}
              source={related.data.source}
            />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<script>
  document.getElementById('share-story')?.addEventListener('click', async () => {
    const payload = {
      title: document.title,
      url: window.location.href
    };

    if (navigator.share) {
      await navigator.share(payload);
      return;
    }

    await navigator.clipboard.writeText(window.location.href);
    const button = document.getElementById('share-story');
    if (button) {
      button.textContent = 'Link copied';
      setTimeout(() => (button.textContent = 'Share story'), 2000);
    }
  });

  const bookmarkBtn = document.getElementById('bookmark-btn') as HTMLButtonElement | null;
  const BOOKMARKS_KEY = 'trustmebro_bookmarks';

  interface Bookmark {
    slug: string;
    title: string;
    image: string;
    category: string;
    savedAt: string;
  }

  function getBookmarks(): Bookmark[] {
    try {
      return JSON.parse(localStorage.getItem(BOOKMARKS_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function saveBookmarks(bookmarks: Bookmark[]) {
    localStorage.setItem(BOOKMARKS_KEY, JSON.stringify(bookmarks));
  }

  function isBookmarked(slug: string): boolean {
    return getBookmarks().some((bookmark) => bookmark.slug === slug);
  }

  function updateBookmarkButton() {
    const slug = bookmarkBtn?.dataset.slug || '';
    if (!bookmarkBtn) return;
    if (isBookmarked(slug)) {
      bookmarkBtn.textContent = 'Saved';
      bookmarkBtn.title = 'Saved article';
    } else {
      bookmarkBtn.textContent = 'Save article';
      bookmarkBtn.title = 'Save article';
    }
  }

  bookmarkBtn?.addEventListener('click', () => {
    const slug = bookmarkBtn.dataset.slug || '';
    const title = bookmarkBtn.dataset.title || '';
    const image = bookmarkBtn.dataset.image || '';
    const category = bookmarkBtn.dataset.category || '';

    let bookmarks = getBookmarks();

    if (isBookmarked(slug)) {
      bookmarks = bookmarks.filter((bookmark) => bookmark.slug !== slug);
      saveBookmarks(bookmarks);
    } else {
      bookmarks.unshift({
        slug,
        title,
        image,
        category,
        savedAt: new Date().toISOString()
      });
      saveBookmarks(bookmarks);
    }

    updateBookmarkButton();
  });

  updateBookmarkButton();

  const askInput = document.getElementById('ask-input') as HTMLInputElement | null;
  const askBtn = document.getElementById('ask-btn') as HTMLButtonElement | null;
  const askResponse = document.getElementById('ask-response');
  const askLoading = document.getElementById('ask-loading');
  const askAnswer = document.getElementById('ask-answer');
  const askAnswerText = document.getElementById('ask-answer-text');
  const askError = document.getElementById('ask-error');

  const articleContent = document.querySelector('.prose')?.textContent || '';
  const articleTitle = document.querySelector('h1')?.textContent || '';
  const articleSlug = window.location.pathname.split('/').pop() || '';

  async function askQuestion() {
    const question = askInput?.value.trim();
    if (!question || question.length < 5) {
      showError('Ask a slightly longer question so the answer has enough context.');
      return;
    }

    askBtn!.textContent = 'Working...';
    askBtn!.setAttribute('disabled', 'true');
    askResponse?.classList.remove('hidden');
    askLoading?.classList.remove('hidden');
    askAnswer?.classList.add('hidden');
    askError?.classList.add('hidden');

    try {
      const response = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          question,
          articleTitle,
          articleContent: articleContent.slice(0, 4000),
          articleSlug
        })
      });

      const data = await response.json();

      if (!response.ok || data.error) {
        showError(data.error || 'Something went wrong. Please try again.');
        return;
      }

      askLoading?.classList.add('hidden');
      askAnswer?.classList.remove('hidden');
      if (askAnswerText) askAnswerText.textContent = data.answer;
    } catch {
      showError('The article assistant could not connect. Please try again.');
    } finally {
      askBtn!.textContent = 'Ask';
      askBtn!.removeAttribute('disabled');
    }
  }

  function showError(message: string) {
    askLoading?.classList.add('hidden');
    askAnswer?.classList.add('hidden');
    askError?.classList.remove('hidden');
    if (askError) askError.textContent = message;
  }

  askBtn?.addEventListener('click', askQuestion);
  askInput?.addEventListener('keypress', (event) => {
    if (event.key === 'Enter') askQuestion();
  });

  const container = document.getElementById('reactions-container');
  const slug = container?.dataset.slug || 'unknown';
  const votedKey = `voted_${slug}`;
  const API_URL = '/api/vibes';

  async function loadReactions() {
    try {
      const response = await fetch(`${API_URL}?slug=${encodeURIComponent(slug)}`);
      const reactions = await response.json();

      document.querySelectorAll('.reaction-btn').forEach((button) => {
        const reaction = (button as HTMLElement).dataset.reaction || '';
        const countEl = button.querySelector('.count');
        if (countEl) countEl.textContent = reactions[reaction] || '0';
      });

      const voted = localStorage.getItem(votedKey);
      if (voted) {
        const votedBtn = document.querySelector(`[data-reaction="${voted}"]`);
        votedBtn?.classList.add('!border-[var(--color-accent-cool)]', '!text-[var(--color-text)]');
        const status = document.getElementById('vote-status');
        if (status) status.textContent = 'Your reaction is already recorded for this story.';
      }
    } catch (error) {
      console.error('Failed to load reactions:', error);
    }
  }

  loadReactions();

  document.querySelectorAll('.reaction-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const voted = localStorage.getItem(votedKey);
      const status = document.getElementById('vote-status');

      if (voted) {
        if (status) status.textContent = 'You already reacted to this story.';
        return;
      }

      const reaction = (button as HTMLElement).dataset.reaction || '';
      button.classList.add('!border-[var(--color-accent-cool)]');
      if (status) status.textContent = 'Saving your reaction...';

      try {
        const response = await fetch(`${API_URL}?slug=${encodeURIComponent(slug)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reaction })
        });

        const reactions = await response.json();

        document.querySelectorAll('.reaction-btn').forEach((item) => {
          const key = (item as HTMLElement).dataset.reaction || '';
          const countEl = item.querySelector('.count');
          if (countEl) countEl.textContent = reactions[key] || '0';
        });

        localStorage.setItem(votedKey, reaction);
        if (status) status.textContent = 'Reaction saved.';
      } catch (error) {
        console.error('Failed to save reaction:', error);
        if (status) status.textContent = 'Could not save your reaction. Please try again.';
        button.classList.remove('!border-[var(--color-accent-cool)]');
      }
    });
  });
</script>
