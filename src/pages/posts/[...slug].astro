---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryEmojis: Record<string, string> = {
  tech: '💻', business: '💰', ai: '🤖', world: '🌍', viral: '🔥',
  entertainment: '🎬', gaming: '🎮', science: '🔬'
};

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { 
    weekday: 'long', 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  });
};

// Calculate reading time (average 200 words per minute)
const content = post.body || '';
const wordCount = content.split(/\s+/).filter(word => word.length > 0).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Get related posts
const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);
---

<Layout title={post.data.title} description={post.data.excerpt} image={post.data.image}>
  <Header />
  
  <main class="max-w-3xl mx-auto px-4 py-12">
    <!-- Article Header -->
    <article>
      <header class="mb-10 text-center">
        <a href={`/category/${post.data.category}`} class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-5 hover:text-purple-400 transition-colors">
          {categoryEmojis[post.data.category] || '📰'} {post.data.category}
        </a>
        
        <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-6 tracking-tight">
          {post.data.title}
        </h1>
        
        <p class="text-lg text-gray-400 mb-8 max-w-2xl mx-auto leading-relaxed">
          {post.data.excerpt}
        </p>
        
        <div class="flex items-center justify-center gap-4 text-sm text-gray-500 mb-8 flex-wrap">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full gradient-bg flex items-center justify-center text-sm">✍️</div>
            <span class="font-medium">{post.data.author}</span>
          </div>
          <span class="hidden sm:inline">•</span>
          <span>{formatDate(post.data.date)}</span>
          <span class="hidden sm:inline">•</span>
          <span>📖 {readingTime} min read</span>
        </div>
        
        <!-- Share Buttons -->
        <div class="flex flex-wrap gap-2 justify-center mb-8">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${Astro.url}`} target="_blank" class="pill hover:bg-[#1da1f2]" title="Share on X">
            𝕏
          </a>
          <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + Astro.url)}`} target="_blank" class="pill hover:bg-[#25D366]" title="Share on WhatsApp">
            💬
          </a>
          <a href={`https://t.me/share/url?url=${encodeURIComponent(String(Astro.url))}&text=${encodeURIComponent(post.data.title)}`} target="_blank" class="pill hover:bg-[#0088cc]" title="Share on Telegram">
            ✈️
          </a>
          <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(String(Astro.url))}&title=${encodeURIComponent(post.data.title)}`} target="_blank" class="pill hover:bg-[#FF4500]" title="Share on Reddit">
            🔴
          </a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(String(Astro.url))}`} target="_blank" class="pill hover:bg-[#0A66C2]" title="Share on LinkedIn">
            💼
          </a>
          <button id="copy-link" class="pill" title="Copy link">
            🔗
          </button>
          <button id="bookmark-btn" class="pill" data-slug={post.slug} data-title={post.data.title} data-image={post.data.image} data-category={post.data.category} title="Save for later">
            🔖
          </button>
          <button id="native-share" class="pill" title="More options">
            📤
          </button>
        </div>
      </header>
      
      <!-- Featured Image -->
      {post.data.image && (
        <figure class="mb-12">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src={post.data.image} 
              alt={post.data.title}
              class="w-full h-auto max-h-[400px] object-cover"
            />
          </div>
          <figcaption class="text-center text-sm text-gray-500 mt-3 italic">
            Image: {post.data.source || 'TrustMeBro'}
          </figcaption>
        </figure>
      )}
      
      <!-- Article Content -->
      <div class="prose max-w-none">
        <Content />
      </div>
      
      <!-- End of Article Divider -->
      <div class="my-12 flex items-center gap-4">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-500 to-transparent"></div>
        <span class="text-2xl">✨</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-500 to-transparent"></div>
      </div>
      
      <!-- Source -->
      {post.data.source && (
        <div class="text-center mb-8">
          <p class="text-sm text-gray-500">
            Originally reported by <span class="font-semibold text-cyan-400">{post.data.source}</span>
          </p>
        </div>
      )}
      
      <!-- Ask a Question Widget -->
      <div class="mt-12 p-6 glass rounded-2xl" id="ask-widget">
        <h3 class="text-lg font-bold mb-3">Got a question about this? 🤔</h3>
        <p class="text-sm text-gray-400 mb-4">Ask anything about this article and get an instant answer.</p>
        
        <div class="flex gap-3">
          <input 
            type="text" 
            id="ask-input"
            placeholder="What does this mean for...?"
            class="flex-1 px-4 py-3 rounded-xl bg-[#0f1724] border border-white/10 focus:outline-none focus:border-purple-500 transition-all text-sm"
            maxlength="500"
          />
          <button 
            id="ask-btn"
            class="px-6 py-3 rounded-xl gradient-bg font-bold text-black hover:scale-[1.02] transition-all text-sm whitespace-nowrap"
          >
            Ask ✨
          </button>
        </div>
        
        <div id="ask-response" class="mt-4 hidden">
          <div id="ask-loading" class="text-sm text-gray-400 hidden">
            Thinking... 💭
          </div>
          <div id="ask-answer" class="p-4 bg-[#0f1724] rounded-xl text-sm hidden">
            <p class="text-gray-300" id="ask-answer-text"></p>
          </div>
          <div id="ask-error" class="text-sm text-red-400 hidden"></div>
        </div>
        
        <p class="text-xs text-gray-500 mt-3">Answers are AI-generated based on the article content.</p>
      </div>
      
      <!-- Reactions -->
      <div class="mt-12 p-6 glass rounded-2xl">
        <p class="text-sm text-gray-400 mb-4">vibe check:</p>
        <div class="flex flex-wrap gap-3" id="reactions-container" data-slug={post.slug}>
          <button class="reaction-btn flex items-center gap-2 text-xl p-3 px-4 rounded-xl glass hover:scale-105 transition-all" data-reaction="fire">
            🔥 <span class="text-sm font-bold count">0</span>
          </button>
          <button class="reaction-btn flex items-center gap-2 text-xl p-3 px-4 rounded-xl glass hover:scale-105 transition-all" data-reaction="cap">
            🧢 <span class="text-sm font-bold count">0</span>
          </button>
          <button class="reaction-btn flex items-center gap-2 text-xl p-3 px-4 rounded-xl glass hover:scale-105 transition-all" data-reaction="skull">
            💀 <span class="text-sm font-bold count">0</span>
          </button>
          <button class="reaction-btn flex items-center gap-2 text-xl p-3 px-4 rounded-xl glass hover:scale-105 transition-all" data-reaction="goat">
            🐐 <span class="text-sm font-bold count">0</span>
          </button>
        </div>
        <p class="text-xs text-gray-500 mt-3" id="vote-status"></p>
      </div>
    </article>
    
    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="mt-16">
        <h2 class="text-xl font-extrabold gradient-text mb-6">more like this 👀</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedPosts.map(rpost => (
            <a href={`/posts/${rpost.slug}`} class="card p-4 group">
              {rpost.data.image && (
                <img src={rpost.data.image} alt={rpost.data.title} class="w-full h-32 object-cover rounded-lg mb-3" />
              )}
              <h3 class="font-bold text-sm line-clamp-2 group-hover:text-cyan-400 transition-colors">{rpost.data.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  
  <Footer />
</Layout>

<script>
  // Copy link
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('copy-link');
    if (btn) {
      btn.textContent = '✅';
      setTimeout(() => btn.textContent = '🔗', 2000);
    }
  });
  
  // Native share
  document.getElementById('native-share')?.addEventListener('click', async () => {
    if (navigator.share) {
      await navigator.share({
        title: document.title,
        url: window.location.href
      });
    }
  });
  
  // ============ BOOKMARK FUNCTIONALITY ============
  const bookmarkBtn = document.getElementById('bookmark-btn') as HTMLButtonElement;
  const BOOKMARKS_KEY = 'trustmebro_bookmarks';
  
  interface Bookmark {
    slug: string;
    title: string;
    image: string;
    category: string;
    savedAt: string;
  }
  
  function getBookmarks(): Bookmark[] {
    try {
      return JSON.parse(localStorage.getItem(BOOKMARKS_KEY) || '[]');
    } catch {
      return [];
    }
  }
  
  function saveBookmarks(bookmarks: Bookmark[]) {
    localStorage.setItem(BOOKMARKS_KEY, JSON.stringify(bookmarks));
  }
  
  function isBookmarked(slug: string): boolean {
    return getBookmarks().some(b => b.slug === slug);
  }
  
  function updateBookmarkButton() {
    const slug = bookmarkBtn?.dataset.slug || '';
    if (isBookmarked(slug)) {
      bookmarkBtn.textContent = '✅';
      bookmarkBtn.title = 'Saved!';
    } else {
      bookmarkBtn.textContent = '🔖';
      bookmarkBtn.title = 'Save for later';
    }
  }
  
  bookmarkBtn?.addEventListener('click', () => {
    const slug = bookmarkBtn.dataset.slug || '';
    const title = bookmarkBtn.dataset.title || '';
    const image = bookmarkBtn.dataset.image || '';
    const category = bookmarkBtn.dataset.category || '';
    
    let bookmarks = getBookmarks();
    
    if (isBookmarked(slug)) {
      // Remove bookmark
      bookmarks = bookmarks.filter(b => b.slug !== slug);
      saveBookmarks(bookmarks);
      bookmarkBtn.textContent = '🔖';
      bookmarkBtn.title = 'Save for later';
    } else {
      // Add bookmark
      bookmarks.unshift({
        slug,
        title,
        image,
        category,
        savedAt: new Date().toISOString()
      });
      saveBookmarks(bookmarks);
      bookmarkBtn.textContent = '✅';
      bookmarkBtn.title = 'Saved!';
    }
  });
  
  // Initialize bookmark button state
  updateBookmarkButton();
  
  // ============ ASK WIDGET ============
  const askInput = document.getElementById('ask-input') as HTMLInputElement;
  const askBtn = document.getElementById('ask-btn');
  const askResponse = document.getElementById('ask-response');
  const askLoading = document.getElementById('ask-loading');
  const askAnswer = document.getElementById('ask-answer');
  const askAnswerText = document.getElementById('ask-answer-text');
  const askError = document.getElementById('ask-error');
  
  // Get article content from the page
  const articleContent = document.querySelector('.prose')?.textContent || '';
  const articleTitle = document.querySelector('h1')?.textContent || '';
  const articleSlug = window.location.pathname.split('/').pop() || '';
  
  async function askQuestion() {
    const question = askInput?.value.trim();
    if (!question || question.length < 5) {
      showError('Please ask a longer question (at least 5 characters)');
      return;
    }
    
    // Show loading state
    askBtn!.textContent = '...';
    askBtn!.setAttribute('disabled', 'true');
    askResponse?.classList.remove('hidden');
    askLoading?.classList.remove('hidden');
    askAnswer?.classList.add('hidden');
    askError?.classList.add('hidden');
    
    try {
      const res = await fetch('/.netlify/functions/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          question,
          articleTitle,
          articleContent: articleContent.slice(0, 4000), // Limit content size
          articleSlug
        })
      });
      
      const data = await res.json();
      
      if (!res.ok || data.error) {
        showError(data.error || 'Something went wrong. Please try again!');
        return;
      }
      
      // Show answer
      askLoading?.classList.add('hidden');
      askAnswer?.classList.remove('hidden');
      if (askAnswerText) {
        askAnswerText.textContent = data.answer;
      }
      
    } catch (err) {
      showError('Couldn\'t connect. Please try again!');
    } finally {
      askBtn!.textContent = 'Ask ✨';
      askBtn!.removeAttribute('disabled');
    }
  }
  
  function showError(msg: string) {
    askLoading?.classList.add('hidden');
    askAnswer?.classList.add('hidden');
    askError?.classList.remove('hidden');
    if (askError) askError.textContent = msg;
  }
  
  askBtn?.addEventListener('click', askQuestion);
  askInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') askQuestion();
  });
  
  // Global Reactions using Netlify Functions
  const container = document.getElementById('reactions-container');
  const slug = container?.dataset.slug || 'unknown';
  const votedKey = `voted_${slug}`;
  const API_URL = '/.netlify/functions/vibes';
  
  // Load reactions from API
  async function loadReactions() {
    try {
      const res = await fetch(`${API_URL}?slug=${encodeURIComponent(slug)}`);
      const reactions = await res.json();
      
      document.querySelectorAll('.reaction-btn').forEach(btn => {
        const reaction = (btn as HTMLElement).dataset.reaction || '';
        const countEl = btn.querySelector('.count');
        if (countEl) countEl.textContent = reactions[reaction] || '0';
      });
      
      // Show if user already voted (still use localStorage for this)
      const voted = localStorage.getItem(votedKey);
      if (voted) {
        const votedBtn = document.querySelector(`[data-reaction="${voted}"]`);
        votedBtn?.classList.add('bg-purple-500/50', 'border-purple-500');
        const status = document.getElementById('vote-status');
        if (status) status.textContent = `you vibed with ${voted === 'fire' ? '🔥' : voted === 'cap' ? '🧢' : voted === 'skull' ? '💀' : '🐐'}`;
      }
    } catch (err) {
      console.error('Failed to load vibes:', err);
    }
  }
  
  loadReactions();
  
  document.querySelectorAll('.reaction-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const voted = localStorage.getItem(votedKey);
      if (voted) {
        const status = document.getElementById('vote-status');
        if (status) status.textContent = "bestie you already vibed on this one 💅";
        return;
      }
      
      const reaction = (btn as HTMLElement).dataset.reaction || '';
      
      // Show optimistic update
      btn.classList.add('bg-purple-500/50', 'border-purple-500', 'scale-110');
      setTimeout(() => btn.classList.remove('scale-110'), 200);
      
      const status = document.getElementById('vote-status');
      if (status) status.textContent = "saving vibe... ⏳";
      
      try {
        // Send to API
        const res = await fetch(`${API_URL}?slug=${encodeURIComponent(slug)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reaction })
        });
        
        const reactions = await res.json();
        
        // Update all counts from server response
        document.querySelectorAll('.reaction-btn').forEach(b => {
          const r = (b as HTMLElement).dataset.reaction || '';
          const countEl = b.querySelector('.count');
          if (countEl) countEl.textContent = reactions[r] || '0';
        });
        
        // Save that user voted
        localStorage.setItem(votedKey, reaction);
        if (status) status.textContent = "vibe recorded globally ✨";
      } catch (err) {
        console.error('Failed to save vibe:', err);
        if (status) status.textContent = "couldn't save vibe, try again 😢";
        btn.classList.remove('bg-purple-500/50', 'border-purple-500');
      }
    });
  });
</script>
