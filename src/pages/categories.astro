---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allPosts = await getCollection('posts');

// Count posts per category
const categoryCounts = allPosts.reduce((acc, post) => {
  const cat = post.data.category;
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categoryEmojis: Record<string, string> = {
  'Tech': '💻',
  'Business': '💰',
  'Entertainment': '🎬',
  'Sports': '⚽',
  'Science': '🔬',
  'Health': '🏥',
  'Politics': '🏛️',
  'World': '🌍',
};

const categoryColors: Record<string, string> = {
  'Tech': 'from-blue-500 to-purple-600',
  'Business': 'from-green-500 to-emerald-600',
  'Entertainment': 'from-pink-500 to-rose-600',
  'Sports': 'from-orange-500 to-red-600',
  'Science': 'from-cyan-500 to-blue-600',
  'Health': 'from-lime-500 to-green-600',
  'Politics': 'from-indigo-500 to-violet-600',
  'World': 'from-amber-500 to-orange-600',
};

// All categories (including ones with 0 posts)
const allCategories = ['Tech', 'Business', 'Entertainment', 'Sports', 'Science', 'Health', 'Politics', 'World'];
---

<Layout title="Categories - trust me bro" description="Browse news by category">
  <Header />
  
  <main class="min-h-screen bg-[--color-bg-primary] pt-8 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page Header -->
      <div class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-black mb-4">
          Browse by <span class="gradient-text">Category</span>
        </h1>
        <p class="text-[--color-text-secondary] text-lg">
          Find the stories that matter to you
        </p>
      </div>

      <!-- Categories Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {allCategories.map(category => {
          const count = categoryCounts[category] || 0;
          const emoji = categoryEmojis[category] || '📰';
          const gradient = categoryColors[category] || 'from-gray-500 to-gray-600';
          
          return (
            <a 
              href={`/category/${category.toLowerCase()}`}
              class="group relative overflow-hidden rounded-2xl p-6 bg-gradient-to-br transition-all hover:scale-105 hover:shadow-xl"
              class:list={[gradient]}
            >
              <div class="relative z-10">
                <span class="text-4xl mb-3 block">{emoji}</span>
                <h2 class="text-xl font-bold text-white mb-1">{category}</h2>
                <p class="text-white/80 text-sm">
                  {count} {count === 1 ? 'story' : 'stories'}
                </p>
              </div>
              
              <!-- Decorative elements -->
              <div class="absolute top-0 right-0 w-20 h-20 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
              <div class="absolute bottom-0 left-0 w-16 h-16 bg-black/10 rounded-full translate-y-1/2 -translate-x-1/2"></div>
              
              <!-- Hover arrow -->
              <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Stats Section -->
      <div class="mt-16 p-8 rounded-2xl bg-[--color-bg-secondary]">
        <h2 class="text-2xl font-bold text-[--color-text-primary] mb-6 text-center">
          📊 Quick Stats
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-black gradient-text">{allPosts.length}</div>
            <div class="text-sm text-[--color-text-secondary]">Total Stories</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-black gradient-text">{Object.keys(categoryCounts).length}</div>
            <div class="text-sm text-[--color-text-secondary]">Active Categories</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-black gradient-text">24/7</div>
            <div class="text-sm text-[--color-text-secondary]">Auto Updates</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-black gradient-text">100%</div>
            <div class="text-sm text-[--color-text-secondary]">Gen Z Vibes</div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
