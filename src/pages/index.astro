---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { categories, categoryEmojis } from '../lib/constants';

const getPostDate = (post: CollectionEntry<'posts'>) =>
  post.data.publishedAt ? new Date(post.data.publishedAt) : post.data.date;

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => getPostDate(b).getTime() - getPostDate(a).getTime());

const featuredPost = sortedPosts[0];
const latestPosts = featuredPost ? sortedPosts.slice(1, 7) : sortedPosts.slice(0, 6);
const nowFiling = featuredPost ? sortedPosts.slice(1, 5) : sortedPosts.slice(0, 4);

const categoryCounts = categories
  .map((category) => ({
    ...category,
    count: sortedPosts.filter((post) => post.data.category === category.slug).length,
  }))
  .filter((category) => category.count > 0)
  .sort((a, b) => b.count - a.count);

const archiveCount = sortedPosts.length;
const sourceCount = new Set(sortedPosts.map((post) => post.data.source).filter(Boolean)).size;
const sectionCount = categoryCounts.length;
const latestUpdate = featuredPost ? getPostDate(featuredPost) : null;

const formatStamp = (date: Date) =>
  date.toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
---

<Layout
  title="Home"
  description="A calmer daily briefing for people who want source labels, searchable context, and less noise."
>
  <Header />

  <main>
    <section class="border-b border-[var(--color-border)]">
      <div class="max-w-7xl mx-auto px-4 py-10 md:py-14">
        <div class="grid gap-8 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
          <div class="space-y-8">
            <div class="space-y-4">
              <p class="eyebrow">Daily briefing</p>
              <h1 class="section-title max-w-4xl text-5xl md:text-7xl">
                A calmer read on what moved online today.
              </h1>
              <p class="muted-copy max-w-2xl text-lg">
                TrustMeBro keeps the internet news cycle readable: visible sources when available,
                exact timestamps, and a searchable archive instead of a pile of noisy widgets.
              </p>
            </div>

            {featuredPost && (
              <article class="surface-strong overflow-hidden rounded-[2rem]">
                <div class="grid gap-0 lg:grid-cols-[1.1fr_0.9fr]">
                  <div class="order-2 p-6 md:p-8 lg:order-1 lg:p-10">
                    <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-muted)]">
                      <a href={`/category/${featuredPost.data.category}`} class="eyebrow" style="margin-bottom: 0;">
                        {categoryEmojis[featuredPost.data.category] || '📰'} {featuredPost.data.category}
                      </a>
                      {featuredPost.data.source && (
                        <>
                          <span class="opacity-40">•</span>
                          <span>{featuredPost.data.source}</span>
                        </>
                      )}
                      {latestUpdate && (
                        <>
                          <span class="opacity-40">•</span>
                          <time datetime={latestUpdate.toISOString()}>{formatStamp(latestUpdate)}</time>
                        </>
                      )}
                    </div>

                    <h2 class="font-heading mt-4 text-4xl leading-tight tracking-[-0.04em] md:text-5xl">
                      {featuredPost.data.title}
                    </h2>
                    <p class="muted-copy mt-4 max-w-2xl text-lg">{featuredPost.data.excerpt}</p>

                    <div class="mt-8 flex flex-wrap gap-3">
                      <a href={`/posts/${featuredPost.slug}`} class="button-primary">Read the lead story</a>
                      <a href="/archive" class="button-secondary">Browse the full archive</a>
                    </div>
                  </div>

                  <div class="order-1 min-h-[280px] border-b border-[var(--color-border)] lg:order-2 lg:border-b-0 lg:border-l">
                    {featuredPost.data.image ? (
                      <img
                        src={featuredPost.data.image}
                        alt={featuredPost.data.title}
                        class="h-full w-full object-cover"
                      />
                    ) : (
                      <div class="gradient-bg flex h-full min-h-[280px] items-center justify-center text-6xl text-white">
                        {categoryEmojis[featuredPost.data.category] || '📰'}
                      </div>
                    )}
                  </div>
                </div>
              </article>
            )}
          </div>

          <aside class="space-y-5">
            <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
              <div class="stat-card">
                <span class="text-sm text-[var(--color-text-muted)]">Stories in archive</span>
                <strong class="stat-value">{archiveCount.toLocaleString()}</strong>
              </div>
              <div class="stat-card">
                <span class="text-sm text-[var(--color-text-muted)]">Active sections</span>
                <strong class="stat-value">{sectionCount}</strong>
              </div>
              <div class="stat-card">
                <span class="text-sm text-[var(--color-text-muted)]">Named sources</span>
                <strong class="stat-value">{sourceCount || '—'}</strong>
              </div>
            </div>

            <div class="surface rounded-[1.75rem] p-6">
              <p class="eyebrow">Why this feels calmer</p>
              <ul class="space-y-4 text-sm text-[var(--color-text-secondary)]">
                <li>Every story card prioritizes source, section, and freshness before visual effects.</li>
                <li>The homepage has one real signup path, one archive path, and one lead story path.</li>
                <li>“Most read” guesses and decorative widgets are gone. The feed now reflects actual chronology.</li>
              </ul>
            </div>

            <NewsletterSignup
              id="briefing"
              compact={true}
              title="Get the useful version"
              description="One working signup. No fake widget. Just the next good briefing in your inbox."
              buttonLabel="Join the briefing"
            />
          </aside>
        </div>
      </div>
    </section>

    {nowFiling.length > 0 && (
      <section class="border-b border-[var(--color-border)]">
        <div class="max-w-7xl mx-auto px-4 py-10">
          <div class="flex items-end justify-between gap-4 mb-6">
            <div>
              <p class="eyebrow">Now filing</p>
              <h2 class="font-heading text-3xl tracking-[-0.04em]">Fresh additions to the desk</h2>
            </div>
            <a href="/archive" class="button-secondary">See everything</a>
          </div>

          <div class="grid gap-4 lg:grid-cols-4">
            {nowFiling.map((post) => {
              const postDate = getPostDate(post);
              return (
                <a href={`/posts/${post.slug}`} class="surface rounded-[1.5rem] p-5 hover:border-[var(--color-accent-cool)] transition-all">
                  <div class="flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.14em] text-[var(--color-text-muted)]">
                    <span class="text-[var(--color-accent-cool)]">{categoryEmojis[post.data.category] || '📰'} {post.data.category}</span>
                    {post.data.source && (
                      <>
                        <span class="opacity-40">•</span>
                        <span>{post.data.source}</span>
                      </>
                    )}
                  </div>
                  <h3 class="font-heading mt-3 text-2xl leading-tight tracking-[-0.03em]">{post.data.title}</h3>
                  <p class="muted-copy mt-3 line-clamp-3 text-sm">{post.data.excerpt}</p>
                  <time class="mt-4 block text-sm text-[var(--color-text-muted)]" datetime={postDate.toISOString()}>
                    {formatStamp(postDate)}
                  </time>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <section>
      <div class="max-w-7xl mx-auto px-4 py-12">
        <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr]">
          <div>
            <div class="flex items-end justify-between gap-4 mb-6">
              <div>
                <p class="eyebrow">Latest coverage</p>
                <h2 class="font-heading text-4xl tracking-[-0.04em]">Read the newest stories first.</h2>
              </div>
              <a href="/archive" class="button-secondary">Open archive</a>
            </div>

            {latestPosts.length > 0 ? (
              <div class="grid gap-6 md:grid-cols-2">
                {latestPosts.map((post) => (
                  <PostCard
                    title={post.data.title}
                    slug={post.slug}
                    excerpt={post.data.excerpt}
                    category={post.data.category}
                    categoryEmoji={categoryEmojis[post.data.category] || '📰'}
                    date={getPostDate(post)}
                    image={post.data.image}
                    source={post.data.source}
                  />
                ))}
              </div>
            ) : (
              <div class="surface rounded-[1.75rem] p-10 text-center">
                <p class="font-heading text-3xl">No stories yet.</p>
                <p class="muted-copy mt-3">Run the fetch job and this desk will populate automatically.</p>
              </div>
            )}
          </div>

          <aside class="space-y-6">
            <div class="surface rounded-[1.75rem] p-6">
              <p class="eyebrow">Browse by section</p>
              <div class="space-y-3">
                {categoryCounts.slice(0, 8).map((category) => (
                  <a
                    href={`/category/${category.slug}`}
                    class="flex items-center justify-between gap-4 rounded-2xl border border-transparent px-4 py-3 transition-all hover:border-[var(--color-accent-cool)] hover:bg-[var(--color-bg-secondary)]"
                  >
                    <span class="flex items-center gap-3 font-medium">
                      <span>{category.emoji}</span>
                      <span>{category.name}</span>
                    </span>
                    <span class="text-sm text-[var(--color-text-muted)]">{category.count}</span>
                  </a>
                ))}
              </div>
            </div>

            <div class="surface rounded-[1.75rem] p-6">
              <p class="eyebrow">Useful paths</p>
              <div class="grid gap-3">
                <a href="/search" class="button-secondary justify-between">Search the archive <span>→</span></a>
                <a href="/saved" class="button-secondary justify-between">Open saved stories <span>→</span></a>
                <a href="/contact" class="button-secondary justify-between">Send a tip or note <span>→</span></a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
